# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=barbearia

# ============================================================
# Backend (FastAPI)
# ============================================================
# Atenção: ao rodar via Docker, usar "db" como hostname (não localhost)
DATABASE_URL=postgresql://postgres:postgres@db:5432/barbearia
TEST_DATABASE_URL=postgresql://postgres:postgres@db:5432/barbearia_test

SECRET_KEY=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=8

ADMIN_EMAIL=admin@marlonbarber.com
ADMIN_PASSWORD=admin123

# Twilio (WhatsApp) — opcional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ============================================================
# Frontend (Next.js)
# ============================================================
# URL da API acessível pelo browser (localhost em dev local com Docker)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# PgAdmin 4
# ============================================================
PGADMIN_DEFAULT_EMAIL=admin@barbershop.com
PGADMIN_DEFAULT_PASSWORD=pgadmin123
